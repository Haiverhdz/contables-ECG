---
import Header from '../components/Header.astro';
import '../styles/global.css';

export interface Props {
  title?: string;
}

const { title = 'Contables ECG' } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="icon" type="image/png" href="/images/logo.png" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&family=Lato:wght@400;700&display=swap" rel="stylesheet">
  </head>
  <body class="bg-gray-50 text-gray-800 min-h-screen flex flex-col">
    <Header />

    <main class="max-w-6xl mx-auto px-4 py-12 flex-1">
      <slot />
    </main>

    <footer class="bg-gray-200 text-gray-700 mt-12">
      <div class="max-w-6xl mx-auto px-4 py-6 text-center space-y-1">
        <a class="text-blue-500" href="/contacto/#preguntas">Preguntas frecuentes</a>
        <p class="text-sm">
          Calle 51 #49-24 kape local 103- Ciudad Bolivar Ant.
        </p>
        <p class="text-sm">
          © {new Date().getFullYear()} Contables ECG. Todos los derechos reservados.
        </p>
        <p class="text-xs text-gray-500">
          Hecho por <a href="https://github.com/Haiverhdz" class="underline hover:text-blue-700">Haiver Hernandez</a>
        </p>
      </div>
    </footer>

    <!-- Botón flotante WhatsApp -->
    <a
      href="https://wa.me/573117045106?text=Hola,%20me%20gustaría%20obtener%20más%20información"
      target="_blank"
      rel="noopener noreferrer"
      class="whatsapp-fab"
      aria-label="Contactar por WhatsApp"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" fill="white" width="28" height="28">
        <path d="M16 0C7.163 0 0 7.163 0 16c0 2.833.738 5.486 2.027 7.793L0 32l8.418-2.003A15.93 15.93 0 0 0 16 32c8.837 0 16-7.163 16-16S24.837 0 16 0zm0 29.333a13.27 13.27 0 0 1-6.77-1.847l-.485-.29-5.003 1.19 1.234-4.862-.317-.5A13.267 13.267 0 0 1 2.667 16C2.667 8.636 8.636 2.667 16 2.667S29.333 8.636 29.333 16 23.364 29.333 16 29.333zm7.27-9.862c-.398-.199-2.355-1.162-2.72-1.294-.366-.133-.632-.199-.898.199-.265.398-1.03 1.294-1.263 1.56-.232.265-.465.298-.863.1-.398-.2-1.681-.62-3.202-1.976-1.183-1.056-1.982-2.36-2.214-2.758-.232-.398-.025-.613.175-.811.18-.178.398-.465.597-.698.2-.232.266-.398.398-.663.133-.265.067-.498-.033-.697-.1-.2-.898-2.165-1.23-2.963-.324-.778-.654-.673-.898-.685l-.765-.013c-.265 0-.697.1-1.063.498-.365.398-1.395 1.362-1.395 3.322s1.428 3.852 1.627 4.117c.2.265 2.81 4.29 6.808 6.017.951.411 1.694.656 2.272.84.955.304 1.824.261 2.511.158.766-.114 2.355-.963 2.688-1.893.332-.93.332-1.727.232-1.893-.1-.166-.365-.265-.763-.464z"/>
      </svg>
      <span class="whatsapp-tooltip">¿Hablamos?</span>
    </a>

  </body>
</html>
