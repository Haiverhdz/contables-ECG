---
const year = new Date().getFullYear();

const quickLinks = [
  { href: "/", label: "Inicio" },
  { href: "/servicios", label: "Servicios" },
  { href: "/nosotros", label: "Nosotros" },
  { href: "/herramientas", label: "Herramientas" },
  { href: "/contacto", label: "Contacto" },
  { href: "/contacto#preguntas", label: "Preguntas frecuentes" },
];
---

<footer class="bg-band text-white">
  <div class="max-w-6xl mx-auto px-4 py-14 grid gap-10 md:grid-cols-[1.3fr_1fr_1fr]">
    <div>
      <a href="/" class="inline-flex items-center">
        <img
          src="/images/logo2.png"
          alt="Contables ECG"
          class="h-10 w-auto rounded-md bg-white/70 px-1.5 py-1"
        />
      </a>
      <p class="mt-4 text-sm leading-relaxed text-white/70 max-w-sm">
        Contadores públicos con asesoría tributaria, contable y financiera para
        empresas y personas naturales.
      </p>
      <p class="mt-4 text-sm text-white/60">
        Calle 51 #49-24 kape local 103, Ciudad Bolívar, Ant.
      </p>
    </div>

    <div>
      <h2 class="text-sm font-semibold uppercase tracking-wide text-white/50 mb-4">
        Enlaces
      </h2>
      <ul class="space-y-2.5 text-sm">
        {quickLinks.map((link) => (
          <li>
            <a href={link.href} class="text-white/75 transition-colors hover:text-accent-2">
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div>
      <h2 class="text-sm font-semibold uppercase tracking-wide text-white/50 mb-4">
        Contacto
      </h2>
      <ul class="space-y-2.5 text-sm">
        <li>
          <a
            href="https://wa.me/573127251340?text=Hola,%20me%20gustaría%20obtener%20más%20información"
            target="_blank"
            rel="noopener noreferrer"
            class="text-white/75 transition-colors hover:text-accent-2"
          >
            WhatsApp
          </a>
        </li>
        <li>
          <a
            href="mailto:contables.ecg@gmail.com"
            class="text-white/75 transition-colors hover:text-accent-2"
          >
            contables.ecg@gmail.com
          </a>
        </li>
      </ul>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div
      class="max-w-6xl mx-auto px-4 py-5 flex flex-col md:flex-row items-center justify-between gap-2 text-xs text-white/50"
    >
      <p>© {year} Contables ECG. Todos los derechos reservados.</p>
      <p>
        Hecho por
        <a
          href="https://github.com/Haiverhdz"
          class="underline decoration-white/30 underline-offset-2 hover:text-accent-2 hover:decoration-accent-2"
          >Haiver Hernandez</a
        >
      </p>
    </div>
  </div>
</footer>
