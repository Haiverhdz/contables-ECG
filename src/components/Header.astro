---
import '../styles/global.css';
import '../styles/Header.css';

const currentPath = Astro.url.pathname;
const isActive = (href: string) => currentPath === href;

const navLinks = [
  {
    href: '/',
    label: 'Inicio',
    icon: 'M2.25 12l8.954-8.955a1.5 1.5 0 012.092 0L22.25 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75',
  },
  {
    href: '/servicios',
    label: 'Servicios',
    icon: 'M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0112 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 01-.673-.38m0 0A2.18 2.18 0 013 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 013.413-.387m7.5 0V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25v.894m7.5 0a48.667 48.667 0 00-7.5 0',
  },
  {
    href: '/nosotros',
    label: 'Nosotros',
    icon: 'M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z',
  },
  {
    href: '/herramientas',
    label: 'Herramientas',
    icon: 'M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437l1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008z',
  },
];

const contactoIcon =
  'M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75';
const faqIcon =
  'M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z';
---

<header class="sticky top-0 z-50 border-b border-line bg-paper/85 backdrop-blur-md">
  <div class="max-w-6xl mx-auto px-4 h-[72px] flex items-center justify-between gap-6">
    <!-- Logo -->
    <a href="/" class="flex items-center shrink-0">
      <img
        src="/images/logo2.png"
        alt="Contables ECG"
        class="h-14 md:h-16 w-auto  rounded-lg px-2 py-1.5"
      />
      <span class="sr-only">Contables ECG</span>
    </a>

    <!-- Nav desktop -->
    <nav class="hidden md:flex items-center gap-1 text-sm font-medium">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            'relative px-3 py-2 transition-colors',
            isActive(link.href) ? 'text-ink' : 'text-ink-muted hover:text-ink',
          ]}
        >
          {link.label}
          {isActive(link.href) && (
            <span class="absolute left-3 right-3 -bottom-px h-0.5 rounded-full bg-accent" />
          )}
        </a>
      ))}

      <div class="relative group">
        <a
          href="/contacto"
          class:list={[
            'inline-flex items-center gap-1 px-3 py-2 transition-colors',
            isActive('/contacto') ? 'text-ink' : 'text-ink-muted hover:text-ink',
          ]}
        >
          Contacto
          <svg
            class="w-4 h-4 transition-transform group-hover:rotate-180"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </a>
        <div class="absolute left-0 top-full pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150">
          <div class="w-56 bg-surface border border-line rounded-xl shadow-card overflow-hidden">
            <a
              href="/contacto#preguntas"
              class="block px-4 py-3 text-sm text-ink-muted hover:bg-surface-sunken hover:text-ink transition-colors"
            >
              Preguntas frecuentes
            </a>
          </div>
        </div>
      </div>
    </nav>

    <div class="flex items-center gap-2">
      <!-- Toggle modo día / noche -->
      <button
        id="theme-toggle"
        type="button"
        class="flex items-center justify-center w-10 h-10 rounded-lg border border-line text-ink hover:bg-surface-sunken transition-colors"
        aria-label="Cambiar a modo día"
      >
        <svg id="icon-sun" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4" />
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
        </svg>
        <svg id="icon-moon" class="w-5 h-5 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" />
        </svg>
      </button>

      <a
        href="/contacto"
        class="hidden md:inline-flex items-center gap-1.5 bg-action text-white text-sm font-semibold px-5 py-2.5 rounded-full shadow-sm hover:shadow-card hover:-translate-y-px transition-all"
      >
        Agendar asesoría
      </a>

      <!-- Botón hamburguesa -->
      <button
        id="drawer-btn"
        class="md:hidden flex items-center justify-center w-10 h-10 rounded-lg border border-line text-ink"
        aria-label="Abrir menú"
        aria-expanded="false"
      >
        <svg class="w-5 h-5" viewBox="0 0 20 20" fill="currentColor">
          <path d="M0 3h20v2H0V3zm0 6h20v2H0V9zm0 6h20v2H0v-2z" />
        </svg>
      </button>
    </div>
  </div>
</header>

<!-- Overlay -->
<div id="drawer-overlay" class="drawer-overlay" aria-hidden="true"></div>

<!-- Drawer lateral derecho -->
<aside id="drawer" class="drawer" aria-label="Menú de navegación" aria-hidden="true">
  <div class="drawer-header">
    <img src="/images/logo3.png" alt="Contables ECG" class="h-11 w-auto bg-white/95 rounded-lg px-2 py-1.5 object-contain" />
    <button id="drawer-close" class="drawer-close" aria-label="Cerrar menú">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <nav class="drawer-nav">
    {navLinks.map((link) => (
      <a href={link.href} class:list={['drawer-link', { 'drawer-link--active': isActive(link.href) }]}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="18" height="18" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d={link.icon} />
        </svg>
        {link.label}
      </a>
    ))}

    <div class="drawer-divider"></div>

    <a href="/contacto" class:list={['drawer-link', { 'drawer-link--active': isActive('/contacto') }]}>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="18" height="18" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d={contactoIcon} />
      </svg>
      Contacto
    </a>
    <a href="/contacto#preguntas" class="drawer-link drawer-link--sub">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="18" height="18" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d={faqIcon} />
      </svg>
      Preguntas frecuentes
    </a>
  </nav>
</aside>

<script>
  const drawerBtn = document.getElementById('drawer-btn');
  const drawerClose = document.getElementById('drawer-close');
  const drawer = document.getElementById('drawer');
  const overlay = document.getElementById('drawer-overlay');

  function openDrawer() {
    drawer?.classList.add('drawer--open');
    overlay?.classList.add('drawer-overlay--visible');
    drawerBtn?.setAttribute('aria-expanded', 'true');
    drawer?.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeDrawer() {
    drawer?.classList.remove('drawer--open');
    overlay?.classList.remove('drawer-overlay--visible');
    drawerBtn?.setAttribute('aria-expanded', 'false');
    drawer?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  drawerBtn?.addEventListener('click', openDrawer);
  drawerClose?.addEventListener('click', closeDrawer);
  overlay?.addEventListener('click', closeDrawer);
  drawer?.querySelectorAll('.drawer-link').forEach((l) => l.addEventListener('click', closeDrawer));
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeDrawer(); });

  // Toggle modo día / noche
  const THEME_KEY = 'theme';
  const root = document.documentElement;
  const themeToggle = document.getElementById('theme-toggle');
  const iconSun = document.getElementById('icon-sun');
  const iconMoon = document.getElementById('icon-moon');

  function syncThemeIcons() {
    const isLight = root.classList.contains('light');
    iconSun?.classList.toggle('hidden', isLight);
    iconMoon?.classList.toggle('hidden', !isLight);
    themeToggle?.setAttribute('aria-label', isLight ? 'Cambiar a modo oscuro' : 'Cambiar a modo día');
  }

  syncThemeIcons();

  themeToggle?.addEventListener('click', () => {
    const isLight = root.classList.toggle('light');
    try {
      localStorage.setItem(THEME_KEY, isLight ? 'light' : 'dark');
    } catch (e) {}
    syncThemeIcons();
  });
</script>
