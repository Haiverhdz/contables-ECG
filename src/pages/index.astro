---
import Layout from '../layouts/Layout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import CtaBand from '../components/CtaBand.astro';
import { services } from '../data/services';

const whyUs = [
  {
    title: 'Cumplimiento sin sorpresas',
    description: 'Declaraciones y obligaciones presentadas a tiempo, siempre.',
    icon: ['M12 3l7 3v6c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6z', 'M9 12l2 2 4-4'],
  },
  {
    title: 'Acompañamiento cercano',
    description: 'Explicamos cada cifra en términos claros, no en jerga contable.',
    icon: ['M4 5h16v11H8l-4 4z'],
  },
  {
    title: 'Visión estratégica',
    description: 'No solo llevamos sus números: le ayudamos a leerlos y decidir con ellos.',
    icon: ['M3 17l6-6 4 4 8-8', 'M15 7h6v6'],
  },
  {
    title: 'Respuesta ágil',
    description: 'Consultas resueltas por WhatsApp o correo, el mismo día hábil.',
    icon: ['M12 21a9 9 0 100-18 9 9 0 000 18z', 'M12 7v5l4 2'],
  },
];

const testimonials = [
  {
    quote:
      'Desde que trabajamos con Contables ECG dejamos de improvisar con la DIAN. Todo llega a tiempo y con explicación clara.',
    name: 'Nombre Apellido',
    role: 'Cargo, Empresa — reemplazar con testimonio real',
  },
  {
    quote:
      'Nos ayudaron a formalizar la empresa desde cero y hoy seguimos trabajando juntos en la planeación tributaria anual.',
    name: 'Nombre Apellido',
    role: 'Cargo, Empresa — reemplazar con testimonio real',
  },
];
---

<Layout title="Inicio - Contables ECG">
  <!-- HERO -->
  <section class="bg-gradient-brand">
    <div class="max-w-6xl mx-auto px-4 py-16 md:py-24 grid lg:grid-cols-[1.05fr_0.85fr] gap-12 lg:gap-16 items-center">
      <div class="animate-fadeIn">
        <p class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-wide text-white mb-4">
          <span class="w-1.5 h-1.5 rounded-full bg-white/80"></span>
          Contadores públicos · Asesoría tributaria y financiera
        </p>
        <h1 class="text-4xl md:text-6xl leading-[1.08] text-white mb-5">
          Cuentas claras.<br />Decisiones <em class="italic">con criterio.</em>
        </h1>
        <p class="text-lg text-white/85 max-w-xl mb-8 leading-relaxed">
          Llevamos la contabilidad, la nómina y las obligaciones tributarias de su empresa con la
          precisión que exige la DIAN y el acompañamiento cercano que su negocio necesita.
        </p>
        <div class="flex flex-wrap items-center gap-4 mb-10">
          <a
            href="/contacto"
            class="inline-flex items-center gap-2 bg-white text-action text-sm font-semibold px-6 py-3.5 rounded-xl shadow-sm hover:shadow-card hover:-translate-y-0.5 transition-all"
          >
            Agende una asesoría
          </a>
          <a
            href="/servicios"
            class="inline-flex items-center gap-2 border border-white/40 text-white text-sm font-semibold px-6 py-3.5 rounded-xl hover:bg-white/10 transition-colors"
          >
            Ver servicios
          </a>
        </div>
        <dl class="flex flex-wrap gap-x-10 gap-y-5 pt-7 border-t border-white/25">
          <div>
            <dt class="font-serif text-3xl font-semibold text-white tabular-nums">+12</dt>
            <dd class="text-sm text-white/75 mt-1 max-w-[16ch]">años asesorando empresas y personas naturales</dd>
          </div>
          <div>
            <dt class="font-serif text-3xl font-semibold text-white tabular-nums">180+</dt>
            <dd class="text-sm text-white/75 mt-1 max-w-[16ch]">empresas con su contabilidad al día</dd>
          </div>
          <div>
            <dt class="font-serif text-3xl font-semibold text-white tabular-nums">100%</dt>
            <dd class="text-sm text-white/75 mt-1 max-w-[16ch]">declaraciones presentadas a tiempo</dd>
          </div>
        </dl>
      </div>

      <div class="relative animate-fadeIn">
        <img
          src="/images/info-rentas-2026.webp"
          alt="Información sobre declaración de renta"
          class="w-full h-auto md:h-[480px] lg:h-[560px] object-contain rounded-2xl shadow-card"
        />
      </div>
    </div>
  </section>

  <section class="bg-surface-sunken/60 border-b border-line">
    <div class="max-w-6xl mx-auto px-4 py-20 md:py-24">
      <div class="max-w-2xl mb-12">
        <p class="text-xs font-semibold uppercase tracking-wide text-accent mb-3">Servicios</p>
        <h2 class="text-3xl md:text-4xl text-ink mb-4">Todo lo que su contabilidad necesita, en un solo lugar</h2>
        <p class="text-ink-muted text-lg leading-relaxed">
          Desde el registro contable del día a día hasta la planeación tributaria de largo plazo.
        </p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {services.map((service) => (
          <ServiceCard icon={service.icon} title={service.title} description={service.description} />
        ))}
      </div>
      <div class="mt-10">
        <a href="/servicios" class="inline-flex items-center gap-1.5 text-action font-semibold text-sm group">
          Ver todos los servicios
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="transition-transform group-hover:translate-x-0.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <section class="bg-gradient-brand">
    <div class="max-w-6xl mx-auto px-4 py-20 md:py-24">
      <div class="max-w-2xl mb-12">
        <p class="text-xs font-semibold uppercase tracking-wide text-white mb-3">¿Por qué elegirnos?</p>
        <h2 class="text-3xl md:text-4xl text-white mb-4">Contabilidad que se entiende, no solo se entrega</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {whyUs.map((reason) => (
          <div>
            <div class="w-11 h-11 rounded-xl bg-white/15 text-white flex items-center justify-center mb-4">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="22" height="22" aria-hidden="true">
                {reason.icon.map((d) => <path d={d} />)}
              </svg>
            </div>
            <h3 class="text-white mb-1.5 font-semibold">{reason.title}</h3>
            <p class="text-sm text-white/80 leading-relaxed">{reason.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-surface-sunken/60 border-y border-line">
    <div class="max-w-6xl mx-auto px-4 py-20 md:py-24">
      <div class="grid md:grid-cols-2 gap-8">
        <div class="bg-surface border border-line rounded-2xl overflow-hidden shadow-sm">
          <img
            src="/images/info-junio.webp"
            alt="Afiliación a seguridad social y ARL"
            class="w-auto h-auto object-contain"
          />
          <div class="p-7">
            <h3 class="text-xl text-ink mb-2">Afiliación a Seguridad Social y ARL</h3>
            <p class="text-sm text-ink-muted leading-relaxed mb-5">
              ¡Cumplir es proteger! Le ayudamos a afiliar a su equipo, evitar sanciones y cumplir la
              ley con tranquilidad.
            </p>
            <a href="/contacto" class="inline-flex items-center gap-1.5 text-action font-semibold text-sm">
              Más información →
            </a>
          </div>
        </div>

        <div class="bg-surface border border-line rounded-2xl overflow-hidden shadow-sm">
          <img
            src="/images/Sello_Distribuidor_Autorizado_Azul_1x.webp"
            alt="Distribuidor autorizado FacturaTech"
            class="w-full h-auto object-contain bg-white p-6"
          />
          <div class="p-7">
            <h3 class="text-xl text-ink mb-2">Impulse su contabilidad con FacturaTech</h3>
            <p class="text-sm text-ink-muted leading-relaxed mb-5">
              Facture, controle y automatice su contabilidad desde una sola plataforma. Rápido,
              confiable y 100% en línea.
            </p>
            <a href="/contacto" class="inline-flex items-center gap-1.5 text-action font-semibold text-sm">
              Conocer más →
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CtaBand />
</Layout>

<style>
  .spark-mask {
    background: var(--color-surface-sunken);
  }
  @media (prefers-reduced-motion: no-preference) {
    .spark-mask {
      animation: reveal-spark 1.2s 0.4s cubic-bezier(0.65, 0, 0.35, 1) forwards;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .spark-mask {
      display: none;
    }
  }
  @keyframes reveal-spark {
    from { clip-path: inset(0 0 0 0%); }
    to { clip-path: inset(0 0 0 100%); }
  }
</style>
