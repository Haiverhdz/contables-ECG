---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Herramientas Contables - Contables ECG">
  <section class="hero-glow bg-gradient-brand">
    <div class="max-w-6xl mx-auto px-4 py-16 md:py-20">
      <p class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-wide text-white mb-4">
        <span class="w-1.5 h-1.5 rounded-full bg-white/80"></span>
        Herramientas
      </p>
      <h1 class="text-4xl md:text-5xl leading-[1.12] text-white mb-4 max-w-2xl">Herramientas <em class="italic text-white/80">Contables.</em></h1>
      <p class="text-lg text-white/85 max-w-2xl leading-relaxed">
        Calcule fácilmente valores contables básicos para su empresa o negocio.
      </p>
    </div>
  </section>

  <section class="bg-surface-sunken/60">
    <div class="max-w-6xl mx-auto px-4 py-16 md:py-20">
      <div class="grid md:grid-cols-3 gap-6">
        <!-- Calculadora IVA -->
        <div class="bg-surface border border-line rounded-2xl shadow-sm p-7">
          <h2 class="text-xl text-ink mb-5 text-center">Calculadora IVA</h2>
          <form id="ivaForm" class="space-y-4">
            <div>
              <label for="valor" class="block text-sm font-medium text-ink-muted mb-1">Valor sin IVA:</label>
              <input
                type="number"
                id="valor"
                class="block w-full bg-paper text-ink border border-line rounded-lg p-2.5 focus:outline-none focus:ring-2 focus:ring-action/30 focus:border-action"
                required
              />
            </div>
            <div>
              <label for="tarifa" class="block text-sm font-medium text-ink-muted mb-1">Tarifa IVA:</label>
              <select
                id="tarifa"
                class="block w-full bg-paper text-ink border border-line rounded-lg p-2.5 focus:outline-none focus:ring-2 focus:ring-action/30 focus:border-action"
              >
                <option value="0.19">19%</option>
                <option value="0.05">5%</option>
                <option value="0">0%</option>
              </select>
            </div>
            <button
              type="submit"
              class="w-full bg-action text-white font-semibold px-4 py-2.5 rounded-lg hover:shadow-card transition-shadow"
            >
              Calcular
            </button>
          </form>
          <div id="resultadoIVA" class="mt-4 text-center text-sm text-ink-muted [&_strong]:text-ink [&_strong]:tabular-nums"></div>
        </div>

        <!-- Retención en la fuente -->
        <div class="bg-surface border border-line rounded-2xl shadow-sm p-7">
          <h2 class="text-xl text-ink mb-5 text-center">Retención en la Fuente</h2>
          <form id="retForm" class="space-y-4">
            <div>
              <label for="valorRet" class="block text-sm font-medium text-ink-muted mb-1">Valor del pago:</label>
              <input
                type="number"
                id="valorRet"
                class="block w-full bg-paper text-ink border border-line rounded-lg p-2.5 focus:outline-none focus:ring-2 focus:ring-action/30 focus:border-action"
                step="0.01"
                required
              />
            </div>
            <div>
              <label for="tarifaRet" class="block text-sm font-medium text-ink-muted mb-1">Tarifa Retención (%):</label>
              <input
                type="number"
                id="tarifaRet"
                class="block w-full bg-paper text-ink border border-line rounded-lg p-2.5 focus:outline-none focus:ring-2 focus:ring-action/30 focus:border-action"
                placeholder="Ej. 10"
                step="0.01"
                required
              />
            </div>
            <button
              type="submit"
              class="w-full bg-action text-white font-semibold px-4 py-2.5 rounded-lg hover:shadow-card transition-shadow"
            >
              Calcular
            </button>
          </form>
          <div id="resultadoRet" class="mt-4 text-center text-sm text-ink-muted [&_strong]:text-ink [&_strong]:tabular-nums"></div>
        </div>

        <!-- Simulador de nómina -->
        <div class="bg-surface border border-line rounded-2xl shadow-sm p-7">
          <h2 class="text-xl text-ink mb-5 text-center">Simulador de Nómina</h2>
          <form id="nominaForm" class="space-y-4">
            <div>
              <label for="salario" class="block text-sm font-medium text-ink-muted mb-1">Salario Básico:</label>
              <input
                type="number"
                id="salario"
                class="block w-full bg-paper text-ink border border-line rounded-lg p-2.5 focus:outline-none focus:ring-2 focus:ring-action/30 focus:border-action"
                required
              />
            </div>
            <div>
              <label for="dias" class="block text-sm font-medium text-ink-muted mb-1">Días Trabajados:</label>
              <input
                type="number"
                id="dias"
                class="block w-full bg-paper text-ink border border-line rounded-lg p-2.5 focus:outline-none focus:ring-2 focus:ring-action/30 focus:border-action"
                value="30"
                required
              />
            </div>
            <button
              type="submit"
              class="w-full bg-action text-white font-semibold px-4 py-2.5 rounded-lg hover:shadow-card transition-shadow"
            >
              Calcular
            </button>
          </form>
          <div id="resultadoNomina" class="mt-4 text-center text-sm text-ink-muted [&_strong]:text-ink [&_strong]:tabular-nums"></div>
        </div>
      </div>
    </div>
  </section>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // IVA
      document.getElementById('ivaForm').addEventListener('submit', (e) => {
        e.preventDefault();
        const valor = parseFloat(document.getElementById('valor').value);
        const tarifa = parseFloat(document.getElementById('tarifa').value);
        const iva = valor * tarifa;
        const total = valor + iva;
        document.getElementById('resultadoIVA').innerHTML =
          `<p>IVA: <strong>$${iva.toLocaleString()}</strong></p>
           <p>Total con IVA: <strong>$${total.toLocaleString()}</strong></p>`;
      });

      document.getElementById('retForm').addEventListener('submit', (e) => {
        e.preventDefault();
        const valor = parseFloat(document.getElementById('valorRet').value);
        const tarifaRet = parseFloat(document.getElementById('tarifaRet').value) / 100;
        const retencion = valor * tarifaRet;
        const neto = valor - retencion;
        document.getElementById('resultadoRet').innerHTML =
          `<p>Retención: <strong>$${retencion.toLocaleString()}</strong></p>
           <p>Neto a pagar: <strong>$${neto.toLocaleString()}</strong></p>`;
      });

      document.getElementById('nominaForm').addEventListener('submit', (e) => {
        e.preventDefault();
        const salario = parseFloat(document.getElementById('salario').value);
        const dias = parseFloat(document.getElementById('dias').value);
        const salarioDia = salario / 30;
        const salarioDevengado = salarioDia * dias;

        const salud = salarioDevengado * 0.04;
        const pension = salarioDevengado * 0.04;
        const neto = salarioDevengado - salud - pension;

        document.getElementById('resultadoNomina').innerHTML =
          `<p>Salario Devengado: <strong>$${salarioDevengado.toLocaleString()}</strong></p>
           <p>Descuento Salud: <strong>$${salud.toLocaleString()}</strong></p>
           <p>Descuento Pensión: <strong>$${pension.toLocaleString()}</strong></p>
           <p><strong>Neto a Pagar: $${neto.toLocaleString()}</strong></p>`;
      });
    });
  </script>
</Layout>
