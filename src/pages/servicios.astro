---
import Layout from '../layouts/Layout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import CtaBand from '../components/CtaBand.astro';
import { services } from '../data/services';
---

<Layout title="Servicios - Contables ECG">
  <section class="hero-glow border-b border-line bg-paper">
    <div class="max-w-6xl mx-auto px-4 py-16 md:py-20">
      <p class="text-xs font-semibold uppercase tracking-wide text-accent mb-3">Servicios</p>
      <h1 class="text-4xl md:text-5xl text-ink mb-4 max-w-2xl">
        Soluciones contables y tributarias, de punta a punta
      </h1>
      <p class="text-lg text-ink-muted max-w-2xl leading-relaxed">
        Ofrecemos acompañamiento integral en materia contable, tributaria y laboral para empresas y
        personas naturales.
      </p>
    </div>
  </section>

  <section class="bg-surface-sunken/60">
    <div class="max-w-6xl mx-auto px-4 py-16 md:py-20">
      <div class="grid md:grid-cols-2 gap-6">
        {services.map((service) => (
          <ServiceCard icon={service.icon} title={service.title} items={service.items} />
        ))}
      </div>
    </div>
  </section>

  <section class="bg-paper">
    <div class="max-w-6xl mx-auto px-4 py-16 md:py-20 text-center">
      <p class="text-xs font-semibold uppercase tracking-wide text-accent mb-3">Nuestro equipo</p>
      <h2 class="text-3xl md:text-4xl text-ink mb-4">Conozca a quienes hacen posible cada servicio</h2>
      <p class="text-ink-muted max-w-xl mx-auto mb-10 leading-relaxed">
        Un equipo cercano, atento a los detalles y comprometido con el cumplimiento de sus
        obligaciones.
      </p>
      <img
        src="/images/quienes-somos.webp"
        alt="Equipo de trabajo Contables ECG"
        class="rounded-2xl shadow-card mx-auto max-h-[420px] w-full max-w-3xl object-cover"
      />
    </div>
  </section>

  <CtaBand />
</Layout>
